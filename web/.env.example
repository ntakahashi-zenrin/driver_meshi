# フロントエンド用 Appwrite 接続情報テンプレート
# このファイルをコピーして .env.local にリネームし、値を入力してください。
# ここに書く値（プロジェクトID等）はブラウザに公開される情報です。
# 秘密のAPIキーはフロントには絶対に置かないでください。

# ★Appwriteのエンドポイント
# クラウドの場合: http://your-server-domain または http://your-server-ip
VITE_APPWRITE_ENDPOINT=http://★your-domain-or-ip★/v1

# ★Appwriteコンソールで確認できるプロジェクトID
VITE_APPWRITE_PROJECT_ID=★project-id★

# ★Appwriteコンソールで確認できるデータベースID（通常は main）
VITE_APPWRITE_DATABASE_ID=main

# ★Appwriteコンソールで確認できるストレージバケットID（通常は media）
VITE_APPWRITE_BUCKET_ID=media
