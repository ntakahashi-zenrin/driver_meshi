# ============================================================
# 店舗マスター管理バックオフィス — 秘密情報
# このファイルをコピーして ".env" を作り、各値を埋めてください。
# .env はGit管理外です（共有先・チャットに貼らないこと）。
# ============================================================

# --- バックオフィスのログイン（管理者は admin 固定） ---
ADMIN_PASSWORD=ここに管理画面ログイン用パスワード

# --- ZENRIN Maps API（検証環境）---
# コンソール「チャネル詳細 > OAuth2.0」で確認した値
ZENRIN_CLIENT_ID=ここにclient_id
ZENRIN_CLIENT_SECRET=ここにclient_secret
# コンソール「チャネル設定 > チャネル一覧」のAPIキー
ZENRIN_API_KEY=ここにAPIキー

# --- Appwrite（ローカル）への接続。先ほどの places を作ったのと同じ構成 ---
APPWRITE_API_KEY=ここにAppwriteのAPIキー（Databases系の権限）

# ============================================================
# 以下は通常そのままでOK（検証環境・ローカル前提のデフォルト）
# ============================================================
# ZENRIN_AUTH_BASE=https://test-auth.zmaps-api.com
# ZENRIN_WEB_BASE=https://test-web.zmaps-api.com
# ZENRIN_JS_DOMAIN=test-js.zmaps-api.com
# APPWRITE_ENDPOINT=http://localhost/v1
# APPWRITE_PROJECT_ID=driver-meshi
# APPWRITE_DATABASE_ID=main
# PORT=8787
# SESSION_SECRET=（未設定ならADMIN_PASSWORDから自動生成）
