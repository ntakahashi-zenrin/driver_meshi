# セットアップスクリプト用 接続情報テンプレート
# このファイルをコピーして .env.local にリネームし、値を入力してください。
# .env.local は絶対に Git にコミットしないでください。

# Appwrite のエンドポイント
# ローカル: http://localhost/v1
# クラウド: http://your-server-ip/v1
APPWRITE_ENDPOINT=http://★your-server-ip★/v1

# プロジェクト ID（Appwrite コンソールで確認）
APPWRITE_PROJECT_ID=driver-meshi

# データベース ID
APPWRITE_DATABASE_ID=main

# ★API キー（Appwrite コンソール → 左メニュー「Overview」→「API Keys」→「Create API key」）
# 必要な権限: databases.read / databases.write / collections.read / collections.write
# ★このキーは秘密情報です。チャット・メールには貼らないでください。
APPWRITE_API_KEY=★ここにAPIキーを貼り付ける★
