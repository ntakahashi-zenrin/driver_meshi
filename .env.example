# ============================================================
# トラックドライバー飯 SNS — 環境変数設定例
# このファイルをコピーして ".env" という名前で保存し、
# サーバーのIPアドレスを書き換えてください。
# ============================================================

# AppwriteサーバーのURL（末尾に /v1 をつける）
# 例: http://192.168.1.100/v1
VITE_APPWRITE_ENDPOINT=http://サーバーのIPアドレス/v1

# 以下3つは変更不要
VITE_APPWRITE_PROJECT_ID=driver-meshi
VITE_APPWRITE_DATABASE_ID=main
VITE_APPWRITE_BUCKET_ID=media
